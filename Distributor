        let cityChart, tierChart, trustScoreChart;

        function initApp() {
            populateFilterOptions();
            renderKPIs();
            renderTable(supplierData);
            initCharts(supplierData);
            
            // Event Listeners
            const filters = ['globalSearch', 'filterTier', 'filterKota', 'filterKategori', 'filterB2B'];
            filters.forEach(id => {
                document.getElementById(id).addEventListener('input', handleFilters);
                if(id !== 'globalSearch') document.getElementById(id).addEventListener('change', handleFilters);
            });
            
            window.addEventListener('keydown', (e) => {
                if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
                    e.preventDefault();
                    document.getElementById('globalSearch').focus();
                }
            });
        }

        function populateFilterOptions() {
            const cities = [...new Set(supplierData.map(s => s.city))].sort();
            const categories = [...new Set(supplierData.map(s => s.category))].sort();
            
            const citySelect = document.getElementById('filterKota');
            const catSelect = document.getElementById('filterKategori');
            
            cities.forEach(city => citySelect.add(new Option(city, city)));
            categories.forEach(cat => catSelect.add(new Option(cat, cat)));
        }

        function renderKPIs() {
            const total = supplierData.length;
            const pabrikCount = supplierData.filter(s => s.tier === "Pabrik").length;
            const distributorCount = supplierData.filter(s => s.tier === "Distributor Regional" || s.tier === "Agen Besar").length;
            const avgScore = (supplierData.reduce((sum, s) => sum + s.score, 0) / total).toFixed(1);

            const kpiData = [
                { label: 'Total Database Master', val: total, icon: 'fa-database', color: 'text-[#c5a880]' },
                { label: 'Pabrik / Manufaktur (OEM)', val: pabrikCount, icon: 'fa-industry', color: 'text-slate-800' },
                { label: 'Distributor & Agen Besar', val: distributorCount, icon: 'fa-truck-fast', color: 'text-slate-800' },
                { label: 'Rata-Rata Trust Score', val: avgScore, icon: 'fa-star-half-stroke', color: 'text-[#c5a880]' }
            ];

            const container = document.getElementById('kpiContainer');
            container.innerHTML = kpiData.map(kpi => `
                <div class="premium-card p-6 flex items-center justify-between group">
                    <div>
                        <div class="text-[10px] text-slate-400 font-display uppercase tracking-widest font-bold mb-2">${kpi.label}</div>
                        <div class="text-3xl font-display font-extrabold text-slate-900 group-hover:text-[#c5a880] transition-colors">${kpi.val}</div>
                    </div>
                    <div class="text-4xl opacity-20 group-hover:opacity-100 transition-opacity ${kpi.color} group-hover:scale-110 transform duration-300">
                        <i class="fa-solid ${kpi.icon}"></i>
                    </div>
                </div>
            `).join('');
        }

        function renderTable(data) {
            const tbody = document.getElementById('supplierTable');
            document.getElementById('recordCount').innerText = data.length;
            
            if (data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="6" class="p-10 text-center text-slate-400 font-medium">Tidak ada data yang cocok dengan kriteria filter.</td></tr>`;
                return;
            }

            tbody.innerHTML = data.map(s => `
                <tr class="hover:bg-slate-50 transition-colors duration-200 group">
                    <td class="p-5">
                        <div class="font-display font-bold text-slate-900 text-sm group-hover:text-[#c5a880] transition-colors">${s.name}</div>
                        <div class="text-[10px] text-slate-400 font-bold tracking-wider uppercase mt-1 truncate max-w-[200px]">${s.id}</div>
                    </td>
                    <td class="p-5">
                        <span class="inline-block px-2.5 py-1 bg-slate-100 text-slate-700 rounded-md text-[10px] font-bold uppercase tracking-wider mb-1">${s.tier}</span>
                        <div class="text-xs text-slate-500 font-medium flex items-center gap-1 mt-1">
                            <i class="fa-solid fa-location-dot text-[#c5a880]"></i> ${s.city}
                        </div>
                    </td>
                    <td class="p-5">
                        <span class="text-xs font-semibold text-slate-700">${s.category}</span>
                    </td>
                    <td class="p-5 font-mono text-xs font-bold text-slate-600">${s.moq}</td>
                    <td class="p-5">
                        <div class="flex gap-1.5 justify-center">
                            ${s.oem === 'Ya' ? '<span title="Mendukung OEM" class="w-7 h-7 rounded-full bg-slate-900 text-[#c5a880] flex items-center justify-center text-[10px] font-bold shadow-sm">O</span>' : ''}
                            ${s.privateLabel === 'Ya' ? '<span title="Mendukung Private Label" class="w-7 h-7 rounded-full bg-slate-900 text-white flex items-center justify-center text-[10px] font-bold shadow-sm">P</span>' : ''}
                            ${s.reseller === 'Ya' ? '<span title="Terima Reseller" class="w-7 h-7 rounded-full bg-white border border-gray-200 text-slate-700 flex items-center justify-center text-[10px] font-bold shadow-sm">R</span>' : ''}
                            ${(s.oem==='Tidak' && s.privateLabel==='Tidak' && s.reseller==='Tidak') ? '<span class="text-xs text-gray-300">-</span>' : ''}
                        </div>
                    </td>
                    <td class="p-5 text-right">
                        <button onclick="showDetails('${s.id}')" class="px-4 py-2 bg-slate-900 hover:bg-[#c5a880] text-white rounded-xl text-xs font-bold transition-all shadow-md shadow-slate-900/10">
                            Analisis
                        </button>
                    </td>
                </tr>
            `).join('');
        }

        function handleFilters() {
            const query = document.getElementById('globalSearch').value.toLowerCase();
            const tier = document.getElementById('filterTier').value;
            const city = document.getElementById('filterKota').value;
            const category = document.getElementById('filterKategori').value;
            const b2b = document.getElementById('filterB2B').value;

            const filtered = supplierData.filter(s => {
                const searchStr = `${s.name} ${s.category} ${s.city} ${s.products.map(p=>p.name).join(' ')}`.toLowerCase();
                const matchQuery = searchStr.includes(query);
                const matchTier = tier === "" || s.tier === tier;
                const matchCity = city === "" || s.city === city;
                const matchCat = category === "" || s.category === category;
                
                let matchB2B = true;
                if (b2b === "OEM") matchB2B = s.oem === "Ya";
                if (b2b === "PrivateLabel") matchB2B = s.privateLabel === "Ya";
                if (b2b === "Reseller") matchB2B = s.reseller === "Ya";

                return matchQuery && matchTier && matchCity && matchCat && matchB2B;
            });

            renderTable(filtered);
            updateCharts(filtered);
        }

        function clearAllFilters() {
            document.getElementById('globalSearch').value = "";
            document.getElementById('filterTier').value = "";
            document.getElementById('filterKota').value = "";
            document.getElementById('filterKategori').value = "";
            document.getElementById('filterB2B').value = "";
            handleFilters();
        }

        function initCharts(data) {
            Chart.defaults.font.family = "'Outfit', sans-serif";
            Chart.defaults.color = "#64748b";

            const cityCtx = document.getElementById('cityChart').getContext('2d');
            cityChart = new Chart(cityCtx, {
                type: 'bar',
                data: { labels: [], datasets: [{ label: 'Total Entitas', data: [], backgroundColor: '#c5a880', borderRadius: 6 }] },
                options: { maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#f1f5f9' } }, x: { grid: { display: false } } } }
            });

            const tierCtx = document.getElementById('tierChart').getContext('2d');
            tierChart = new Chart(tierCtx, {
                type: 'doughnut',
                data: { labels: [], datasets: [{ data: [], backgroundColor: ['#0f172a', '#c5a880', '#cbd5e1'], borderWidth: 0 }] },
                options: { maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { padding: 20, usePointStyle: true } } }, cutout: '70%' }
            });

            const scoreCtx = document.getElementById('trustScoreChart').getContext('2d');
            trustScoreChart = new Chart(scoreCtx, {
                type: 'line',
                data: { labels: [], datasets: [{ label: 'Trust Score', data: [], borderColor: '#0f172a', backgroundColor: 'rgba(15, 23, 42, 0.05)', fill: true, tension: 0.4, pointBackgroundColor: '#c5a880' }] },
                options: { maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { min: 70, max: 100, grid: { color: '#f1f5f9' } }, x: { display: false } } }
            });

            updateCharts(data); 
        }

        function updateCharts(filteredData) {
            const cityCounts = {};
            const tierCounts = {};
            
            filteredData.forEach(s => {
                cityCounts[s.city] = (cityCounts[s.city] || 0) + 1;
                tierCounts[s.tier] = (tierCounts[s.tier] || 0) + 1;
            });

            cityChart.data.labels = Object.keys(cityCounts);
            cityChart.data.datasets[0].data = Object.values(cityCounts);
            cityChart.update();

            tierChart.data.labels = Object.keys(tierCounts);
            tierChart.data.datasets[0].data = Object.values(tierCounts);
            tierChart.update();

            trustScoreChart.data.labels = filteredData.map(s => s.name.substring(0, 15));
            trustScoreChart.data.datasets[0].data = filteredData.map(s => s.score);
            trustScoreChart.update();
        }

        function switchTab(tab) {
            ['analytics', 'database'].forEach(s => {
                document.getElementById(`section-${s}`).classList.add('hidden');
                document.getElementById(`tab-${s}`).classList.remove('active');
            });
            document.getElementById(`section-${tab}`).classList.remove('hidden');
            document.getElementById(`tab-${tab}`).classList.add('active');
        }

        function showDetails(id) {
            const s = supplierData.find(item => item.id === id);
            if(!s) return;

            document.getElementById('modalTitle').innerText = s.name;
            document.getElementById('modalTierBadge').innerText = s.tier;
            document.getElementById('modalCategory').innerText = s.category;
            
            document.getElementById('modalAddress').innerText = s.address;
            document.getElementById('modalMaps').href = s.maps;

            const noData = '<span class="italic text-slate-400 text-xs">Belum Diverifikasi</span>';
            document.getElementById('modalContacts').innerHTML = `
                <div class="flex items-center gap-3"><div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500"><i class="fa-solid fa-phone"></i></div><span class="text-sm font-medium">${s.phone !== 'Belum Diverifikasi' ? s.phone : noData}</span></div>
                <div class="flex items-center gap-3"><div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center text-green-600"><i class="fa-brands fa-whatsapp"></i></div><span class="text-sm font-medium">${s.whatsapp !== 'Belum Diverifikasi' ? s.whatsapp : noData}</span></div>
                <div class="flex items-center gap-3"><div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600"><i class="fa-solid fa-envelope"></i></div><span class="text-sm font-medium">${s.email !== 'Belum Diverifikasi' ? s.email : noData}</span></div>
            `;

            document.getElementById('modalVerification').innerHTML = `<i class="fa-solid fa-circle-check mt-0.5"></i> <span>${s.verification}</span>`;
            document.getElementById('modalScore').innerHTML = `${s.score}<span class="text-sm text-slate-400 font-medium">/100</span>`;
            document.getElementById('modalMoq').innerText = s.moq;

            document.getElementById('modalB2BBadges').innerHTML = `
                ${s.oem === 'Ya' ? '<span class="px-2 py-1 bg-slate-900 text-[#c5a880] text-[10px] font-bold rounded">OEM</span>' : ''}
                ${s.privateLabel === 'Ya' ? '<span class="px-2 py-1 bg-slate-700 text-white text-[10px] font-bold rounded">Private Label</span>' : ''}
                ${s.reseller === 'Ya' ? '<span class="px-2 py-1 border border-gray-300 text-slate-600 text-[10px] font-bold rounded">Reseller/Grosir</span>' : ''}
            `;

            const productHtml = s.products.map(p => `
                <tr class="hover:bg-slate-50 transition-colors">
                    <td class="py-3 px-4 text-sm font-medium text-slate-700">${p.name}</td>
                    <td class="py-3 px-4 font-mono text-sm font-bold text-green-700">${p.price}</td>
                </tr>
            `).join('');
            document.getElementById('modalProducts').innerHTML = productHtml;
            document.getElementById('modalNotes').innerText = s.notes || "Belum ada catatan tambahan.";

            const modal = document.getElementById('detailModal');
            const card = document.getElementById('modalCard');
            modal.classList.remove('hidden');
            void modal.offsetWidth; 
            modal.classList.remove('opacity-0');
            card.classList.remove('scale-95');
            document.body.classList.add('overflow-hidden');
        }

        function closeModal() {
            const modal = document.getElementById('detailModal');
            const card = document.getElementById('modalCard');
            modal.classList.add('opacity-0');
            card.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
                document.body.classList.remove('overflow-hidden');
            }, 300);
        }

        function exportToCSV() {
            // Define CSV headers
            const headers = [
                "ID", "Nama Perusahaan", "Tier", "Kategori", "Kota", "Alamat Lengkap", "Google Maps", 
                "Telepon", "WhatsApp", "Email", "Website", "Shopee", "Tokopedia", 
                "Reseller", "OEM", "Private Label", "MOQ", "Score", "Status Verifikasi", "Catatan Analis", "Contoh Produk/Harga"
            ];
            
            // Build CSV rows
            const csvRows = [headers.join(',')];
            
            supplierData.forEach(s => {
                // Formatting products into a single string for the CSV cell
                const prodString = s.products.map(p => `${p.name} (${p.price})`).join(' | ');
                
                const row = [
                    s.id, `"${s.name}"`, s.tier, s.category, s.city, `"${s.address}"`, s.maps,
                    s.phone, s.whatsapp, s.email, s.website, s.shopee, s.tokopedia,
                    s.reseller, s.oem, s.privateLabel, `"${s.moq}"`, s.score, `"${s.verification}"`, `"${s.notes || ''}"`, `"${prodString}"`
                ];
                csvRows.push(row.join(','));
            });

            // Create Blob and Download Link
            const csvData = csvRows.join('\n');
            const blob = new Blob([csvData], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            
            const link = document.createElement("a");
            link.setAttribute("href", url);
            link.setAttribute("download", "Master_Database_Supplier_Jatim_2026.csv");
            link.style.visibility = 'hidden';
            
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }

        // Start app
        window.onload = initApp;
    </script>
</body>
